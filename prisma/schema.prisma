generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Character {
  id        String   @id @default(uuid())
  name      String
  scrolls   Scroll[]
  createdAt DateTime @default(now())
  sessionId String
}

model Scroll {
  id          String   @id @default(uuid())
  label        String
  effect      String?
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}